################################################################################
# Woodruff & van Dijk Framework: Covariate Cleaning and Coding
# REVISED: Added mat_race, mom_age_preg, planned_preg, prenatal_vit,
#          mh_p_famhx__dep__moth_001 (recode per PI guidance);
#          removed child sex and child race
################################################################################

library(dplyr)

# -----------------------------
# 1) Baseline only
# -----------------------------
Cov_baseline <- Cov %>%
  filter(session_id == "ses-00A")

# sanity check
n_distinct(Cov_baseline$participant_id)
nrow(Cov_baseline)

# -----------------------------
# 2) Recode / label key covariates
# -----------------------------
Cov_baseline <- Cov_baseline %>%
  mutate(

    # --- Income (6-level): special missing -> NA, then factor ---
    ab_g_dyn__cohort_income__hhold__6lvl = na_if(ab_g_dyn__cohort_income__hhold__6lvl, 777),
    ab_g_dyn__cohort_income__hhold__6lvl = na_if(ab_g_dyn__cohort_income__hhold__6lvl, 999),
    ab_g_dyn__cohort_income__hhold__6lvl = factor(
      ab_g_dyn__cohort_income__hhold__6lvl,
      levels = c(1, 2, 3, 4, 5, 6),
      labels = c(
        "<$25,000",
        "$25,000-49,999",
        "$50,000-74,999",
        "$75,000-99,999",
        "$100,000-199,999",
        "$200,000+"
      )
    ),

    # --- Education (5-level ordinal, treated as factor) ---
    ab_g_dyn__cohort_edu__cgs = factor(
      ab_g_dyn__cohort_edu__cgs,
      levels = c(1, 2, 3, 4, 5),
      labels = c(
        "<= High School (No diploma)",
        "High School/GED",
        "Some College",
        "Bachelor's",
        "Graduate/Professional"
      )
    ),

    # --- Mother age at pregnancy (rename for legibility) ---
    mom_age_preg = as.numeric(ab_p_demo__age__slf_001),

    # --- Planned pregnancy: 999 -> NA, then factor ---
    planned_preg = na_if(as.numeric(ph_p_dhx_006), 999),
    planned_preg = factor(
      planned_preg,
      levels = c(0, 1),
      labels = c("No", "Yes")
    ),

    # --- Prenatal vitamins: 999/444 -> NA, then factor ---
    prenatal_vit = na_if(as.numeric(ph_p_dhx__vit_001), 999),
    prenatal_vit = na_if(prenatal_vit, 444),
    prenatal_vit = factor(
      prenatal_vit,
      levels = c(0, 1),
      labels = c("No", "Yes")
    ),

    # --- Maternal depression family history (recode per PI guidance) ---
    # Logic:
    #   mh_p_famhx_001 == 1 (has family history) AND
    #   mh_p_famhx__dep_001 == 1 (depression in family) AND
    #   mh_p_famhx__dep__moth_001 == 1 -> 1 (maternal dep history positive)
    #
    #   mh_p_famhx_001 == 1 AND mh_p_famhx__dep_001 == 0
    #   -> 0 (family hx positive but no depression reported)
    #
    #   mh_p_famhx_001 == 1 AND mh_p_famhx__dep_001 == 1 AND
    #   mh_p_famhx__dep__moth_001 == 0
    #   -> 0 (depression in family but not in mother specifically)
    #
    #   All else -> NA
    #
    # Rationale: NAs in mh_p_famhx__dep__moth_001 previously treated as
    # missing are in many cases true negatives (screener answered but no
    # maternal dep reported). This recode recovers those cases.
    .fhx  = as.numeric(mh_p_famhx_001),
    .dep  = as.numeric(mh_p_famhx__dep_001),
    .moth = as.numeric(mh_p_famhx__dep__moth_001),

    mh_p_famhx__dep__moth_001 = case_when(
      .fhx == 1 & .dep == 1 & .moth == 1  ~ 1L,
      .fhx == 1 & .dep == 0               ~ 0L,
      .fhx == 1 & .dep == 1 & .moth == 0  ~ 0L,
      TRUE                                 ~ NA_integer_
    ),

    mh_p_famhx__dep__moth_001 = factor(
      mh_p_famhx__dep__moth_001,
      levels = c(0L, 1L),
      labels = c("No", "Yes")
    )
  ) %>%
  select(-starts_with(".fhx"), -starts_with(".dep"), -starts_with(".moth"))

# -----------------------------
# 3) Derive mat_race from multi-select indicators
#    Logic: if more than one category TRUE -> Multiracial
#           if exactly one TRUE -> that category
#           if none TRUE or all NA -> NA
# -----------------------------

Cov_baseline <- Cov_baseline %>%
  mutate(
    .r_white = as.numeric(ab_p_demo__race__slf_001___10) == 1,
    .r_black = as.numeric(ab_p_demo__race__slf_001___11) == 1,
    .r_aian  = as.numeric(ab_p_demo__race__slf_001___12) == 1 |  # Am. Indian
               as.numeric(ab_p_demo__race__slf_001___13) == 1,   # Alaska Native
    .r_nhpi  = as.numeric(ab_p_demo__race__slf_001___14) == 1 |  # Native Hawaiian
               as.numeric(ab_p_demo__race__slf_001___15) == 1 |  # Guamanian
               as.numeric(ab_p_demo__race__slf_001___16) == 1 |  # Samoan
               as.numeric(ab_p_demo__race__slf_001___17) == 1,   # Other Pacific Islander
    .r_asian = as.numeric(ab_p_demo__race__slf_001___18) == 1 |  # Asian Indian
               as.numeric(ab_p_demo__race__slf_001___19) == 1 |  # Chinese
               as.numeric(ab_p_demo__race__slf_001___20) == 1 |  # Filipino
               as.numeric(ab_p_demo__race__slf_001___21) == 1 |  # Japanese
               as.numeric(ab_p_demo__race__slf_001___22) == 1 |  # Korean
               as.numeric(ab_p_demo__race__slf_001___23) == 1 |  # Vietnamese
               as.numeric(ab_p_demo__race__slf_001___24) == 1,   # Other Asian
    .r_other = as.numeric(ab_p_demo__race__slf_001___25) == 1,   # Other Race
    .r_dta   = as.numeric(ab_p_demo__race__slf_001___777) == 1,  # Decline to answer
    .r_dk    = as.numeric(ab_p_demo__race__slf_001___999) == 1,  # Don't know

    # Sum of substantive race flags only
    .r_sum = rowSums(
      cbind(.r_white, .r_black, .r_aian, .r_nhpi, .r_asian, .r_other),
      na.rm = TRUE
    ),

    mat_race = case_when(
      .r_dta | .r_dk               ~ NA_character_,
      .r_sum > 1                   ~ "Multiracial",
      .r_white & .r_sum == 1      ~ "White",
      .r_black & .r_sum == 1      ~ "Black/African American",
      .r_aian  & .r_sum == 1      ~ "American Indian/Alaska Native",
      .r_nhpi  & .r_sum == 1      ~ "Native Hawaiian/Pacific Islander",
      .r_asian & .r_sum == 1      ~ "Asian",
      .r_other & .r_sum == 1      ~ "Other",
      .r_sum == 0                  ~ NA_character_,
      TRUE                         ~ NA_character_
    ),

    mat_race = factor(mat_race, levels = c(
      "White",
      "Black/African American",
      "American Indian/Alaska Native",
      "Native Hawaiian/Pacific Islander",
      "Asian",
      "Other",
      "Multiracial"
    ))
  ) %>%
  select(-starts_with(".r_"))

