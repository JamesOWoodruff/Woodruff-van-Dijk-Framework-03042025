# -----------------------------
str(Cov_baseline$ab_g_dyn__cohort_income__hhold__6lvl)
str(Cov_baseline$ab_g_dyn__cohort_edu__cgs)
str(Cov_baseline$mom_age_preg)
str(Cov_baseline$planned_preg)
