############################################################

MED_DHQ_Data_xlsx <- MED_DHQ_Data_xlsx %>%
  mutate(
    # -------------------------
    # Alcohol (before/after/any)
    # -------------------------
    alc_before = as.integer(
      is_yes_dhx(ph_p_dhx__alc_001a) |
        is_pos(ph_p_dhx__alc_001a__01) |
        is_pos(ph_p_dhx__alc_001a__02) |
        is_pos(ph_p_dhx__alc_001a__03)
    ),
    alc_after = as.integer(
      is_yes_dhx(ph_p_dhx__alc_001b) |
        is_pos(ph_p_dhx__alc_001b__01) |
        is_pos(ph_p_dhx__alc_001b__02) |
        is_pos(ph_p_dhx__alc_001b__03)
    ),
    alc_any = as.integer(alc_before == 1L | alc_after == 1L),

    # -------------------------
    # Cocaine/Crack (before/after/any)
    # -------------------------
    coc_before = as.integer(
      is_yes_dhx(ph_p_dhx__coc_001a) |
        is_pos(ph_p_dhx__coc_001a__01)
    ),
    coc_after = as.integer(
      is_yes_dhx(ph_p_dhx__coc_001b) |
        is_pos(ph_p_dhx__coc_001b__01)
    ),
    coc_any = as.integer(coc_before == 1L | coc_after == 1L),

    # -------------------------
    # Marijuana (before/after/any)
    # -------------------------
    mj_before = as.integer(
      is_yes_dhx(ph_p_dhx__mj_001a) |
        is_pos(ph_p_dhx__mj_001a__01)
    ),
    mj_after = as.integer(
      is_yes_dhx(ph_p_dhx__mj_001b) |
        is_pos(ph_p_dhx__mj_001b__01)
    ),
    mj_any = as.integer(mj_before == 1L | mj_after == 1L),

    # -------------------------
    # Nicotine/Tobacco (before/after/any)
    # -------------------------
    nic_before = as.integer(
      is_yes_dhx(ph_p_dhx__nic_001a) |
        is_pos(ph_p_dhx__nic_001a__01)
    ),
    nic_after = as.integer(
      is_yes_dhx(ph_p_dhx__nic_001b) |
        is_pos(ph_p_dhx__nic_001b__01)
    ),
    nic_any = as.integer(nic_before == 1L | nic_after == 1L),

    # -------------------------
    # Heroin/Morphine (direct opioid informant)
    # -------------------------
    opi_hm_before = as.integer(
      is_yes_dhx(ph_p_dhx__opi_001a) |
        is_pos(ph_p_dhx__opi_001a__01)
    ),
    opi_hm_after = as.integer(
      is_yes_dhx(ph_p_dhx__opi_001b) |
        is_pos(ph_p_dhx__opi_001b__01)
    ),
    opi_hm_any = as.integer(opi_hm_before == 1L | opi_hm_after == 1L),

    # -------------------------
    # Caffeine (pregnancy-wide item only; no before/after in DHX)
    # -------------------------
    caff_any = as.integer(
      is_yes_dhx(ph_p_dhx__caff_001) |
        is_pos(ph_p_dhx__caff_001__01) |
        is_pos(ph_p_dhx__caff_001__02) |
        is_pos(ph_p_dhx__caff_001__03)
    )
  ) %>%
  mutate(
    # ------------------------------------------------------
    # MERGE DIRECT OPI ITEM INTO EXISTING OPIOID CLASS FLAGS
    # (prevents missing opioid users who didn't list it in Rx text)
    # ------------------------------------------------------
    opioid_before = as.integer(opioid_before == 1L | opi_hm_before == 1L),
    opioid_after  = as.integer(opioid_after  == 1L | opi_hm_after  == 1L),

    prenatal_opioid_exposure = as.integer(prenatal_opioid_exposure == 1L | opi_hm_any == 1L)
  ) %>%
  mutate(
    # Recompute only/both after opioid merge
    opioid_before_only      = as.integer(opioid_before == 1L & opioid_after == 0L),
    opioid_after_only       = as.integer(opioid_before == 0L & opioid_after == 1L),
    opioid_before_and_after = as.integer(opioid_before == 1L & opioid_after == 1L)
  )

