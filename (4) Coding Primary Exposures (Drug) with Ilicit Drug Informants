collapse_hits <- function(text_vec, pattern) {
  text_vec_lower <- tolower(text_vec %||% "")
  hits_list <- stringr::str_extract_all(text_vec_lower, pattern)
  vapply(hits_list, function(hits) {
    hits <- unique(hits[!is.na(hits) & hits != ""])
    if (length(hits) == 0) NA_character_ else paste(hits, collapse = "; ")
  }, FUN.VALUE = character(1))
}

